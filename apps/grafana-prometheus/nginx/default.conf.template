# Nginx HTTPS template สำหรับ Grafana+Prometheus (golden rule #3)
# ใช้เมื่อต้องการเปิด HTTPS ภายหลัง — copy ไป /opt/monitoring/nginx/default.conf
# พร้อม mount SSL certificates ที่ /etc/nginx/ssl/
#
# วิธีใช้:
#   1. สร้างหรือรับ SSL cert (เช่น Let's Encrypt) → fullchain.pem + privkey.pem
#   2. Mount cert ใน docker-compose.yml nginx service:
#      volumes:
#        - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
#        - /etc/nginx/ssl:/etc/nginx/ssl:ro
#   3. เปิด port 443 ใน docker-compose.yml + UFW
#   4. Restart nginx container

limit_req_zone $binary_remote_addr zone=grafana_login:10m rate=5r/s;

server {
    listen 80;
    server_name _;
    # Redirect HTTP → HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name _;

    ssl_certificate /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    client_max_body_size 10m;

    # Security headers
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-XSS-Protection "1; mode=block";
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Rate-limit login endpoints
    location ~ ^/(api/)?login {
        limit_req zone=grafana_login burst=10 nodelay;
        proxy_pass http://grafana:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://grafana:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}