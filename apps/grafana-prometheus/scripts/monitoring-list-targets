#!/usr/bin/env bash
set -euo pipefail

TARGET_DIR=/opt/monitoring/prometheus/targets

if [ "$(id -u)" -ne 0 ]; then
  echo "Run with sudo: sudo monitoring-list-targets" >&2
  exit 1
fi

for file in "$TARGET_DIR"/*.yml; do
  echo
  echo "== $(basename "$file") =="
  sed -n '/targets:/,/labels:/p' "$file" | sed '/labels:/d' || true
done
