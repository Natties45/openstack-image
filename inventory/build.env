# Image build environment template
# Copy to build/tmp/<app>-build.env and fill in real values
# This file is gitignored — DO NOT commit real credentials

# Generic Image Build VM
IMAGE_BUILD_HOST=CHANGE_ME
IMAGE_BUILD_USER=root
IMAGE_BUILD_PASSWORD=CHANGE_ME
IMAGE_BUILD_SSH_PORT=22
IMAGE_BUILD_SERVER_ID=CHANGE_ME
IMAGE_BUILD_IMAGE_NAME=ubuntu-26.04-<APP_NAME>-YYYYMMDD